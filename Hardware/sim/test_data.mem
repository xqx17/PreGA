// ============================================================================
//  File: test_data.mem (Comprehensive)
//  Description: 为全面的功能验证初始化主内存模型。
// ============================================================================

// --- 数据块 1: 用于基础的 Add/Check/Remove 测试 ---
// 地址: 0x1000, 长度: 16 字节 (4 个字)
@400
AABBCCDD
11223344
55667788
9900EEFF

// --- 数据块 2: 用于 FIFO 压力测试 (第一个 ADD 命令) ---
// 地址: 0x2000, 长度: 32 字节 (8 个字)
@800
01020304
05060708
090A0B0C
0D0E0F00
11111111
22222222
33333333
44444444

// --- 数据块 3: 用于 FIFO 压力测试 (第二个 ADD 命令) ---
// 地址: 0x3000, 长度: 16 字节 (4 个字)
@C00
F0F0F0F0
E1E1E1E1
D2D2D2D2
C3C3C3C3

// --- 数据块 4: 用于检查一个不存在的元素 (误报测试) ---
// 该数据在内存中，但从未被添加到布隆过滤器中。
// 地址: 0x4000, 长度: 16 字节 (4 个字)
@1000
DEADBEEF
CAFEBABE
12345678
87654321
